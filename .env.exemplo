# Automação de Vagas — configurações
# Este arquivo é gerado automaticamente pelo instalar.bat
# Edite aqui se precisar alterar algum dado

EMAIL_REMETENTE=seu@gmail.com
EMAIL_DESTINO=seu@gmail.com

# Necessário apenas para enviar candidaturas por e-mail
# Como gerar: myaccount.google.com > Segurança > Senhas de app
GMAIL_APP_PASSWORD=

CIDADE=São Paulo
ESTADO=SP

# Deixe em branco — a análise de currículo funciona sem configuração
GEMINI_API_KEY=
